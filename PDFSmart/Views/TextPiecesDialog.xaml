<Window x:Class="SmartPdfEditor.Views.TextPiecesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SmartPdfEditor.Views"
        xmlns:vm="clr-namespace:SmartPdfEditor.ViewModels"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Background="{DynamicResource AppSurfaceBrush}"
        TextElement.Foreground="{DynamicResource AppInkBrush}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        FontFamily="{DynamicResource AppFontFamily}"
        Title="Smart Text Extraction" Height="700" Width="600"
        WindowStartupLocation="CenterScreen">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="Extracted Text Blocks" 
                       Style="{DynamicResource MaterialDesignHeadline5TextBlock}" Margin="0,0,0,5"/>
            <TextBlock Text="Select pieces to copy all at once, or copy blocks individually." 
                       Opacity="0.7" FontSize="12"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Pieces}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="{DynamicResource MaterialDesignDivider}" 
                                BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" VerticalAlignment="Top" Margin="0,2,10,0"/>

                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding Metadata}" FontSize="10" Opacity="0.5" Margin="0,0,0,5"/>
                                    <TextBox Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}" 
                                             Style="{DynamicResource MaterialDesignFlatTextBox}"
                                             TextWrapping="Wrap" AcceptsReturn="True"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top">
                                    <Button Style="{DynamicResource MaterialDesignIconButton}" 
                                            Command="{Binding CopyPieceCommand}" ToolTip="Copy this piece">
                                        <materialDesign:PackIcon Kind="ContentCopy" />
                                    </Button>
                                    <Button Style="{DynamicResource MaterialDesignIconButton}" 
                                            Command="{Binding SaveToPdfCommand}" ToolTip="Save change to PDF"
                                            Foreground="{DynamicResource PrimaryHueMidBrush}">
                                        <materialDesign:PackIcon Kind="ContentSave" />
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Grid Grid.Row="2" Margin="0,15,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button Style="{DynamicResource MaterialDesignOutlinedButton}" Content="COPY SELECTED" 
                        Command="{Binding CopyAllSelectedCommand}" Width="150" Margin="0,0,10,0"/>
            </StackPanel>
            
            <Button Style="{DynamicResource MaterialDesignRaisedButton}" Content="CLOSE" 
                    HorizontalAlignment="Right" Command="{Binding CloseCommand}" Width="100"/>
        </Grid>
    </Grid>
</Window>
