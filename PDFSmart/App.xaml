<Application x:Class="SmartPdfEditor.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:SmartPdfEditor"
             xmlns:converters="clr-namespace:SmartPdfEditor.Converters"
             Startup="OnStartup">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Light.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign2.Defaults.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignColors;component/Themes/Recommended/Primary/MaterialDesignColor.Green.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignColors;component/Themes/Recommended/Secondary/MaterialDesignColor.LightGreen.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <FontFamily x:Key="AppFontFamily">Candara</FontFamily>
            <FontFamily x:Key="AppDisplayFontFamily">Georgia</FontFamily>

            <Color x:Key="AppInkColor">#1F2428</Color>
            <Color x:Key="AppInkMutedColor">#5E6A71</Color>
            <Color x:Key="AppAccentColor">#0E7C66</Color>
            <Color x:Key="AppAccentSoftColor">#D7EFE9</Color>
            <Color x:Key="AppSurfaceColor">#F7F3EE</Color>
            <Color x:Key="AppSidebarStartColor">#F0F8F6</Color>
            <Color x:Key="AppSidebarEndColor">#E6EFEA</Color>
            <Color x:Key="AppCardColor">#FFFFFF</Color>
            <Color x:Key="AppBorderColor">#D6D9DC</Color>

            <SolidColorBrush x:Key="AppInkBrush" Color="{StaticResource AppInkColor}" />
            <SolidColorBrush x:Key="AppInkMutedBrush" Color="{StaticResource AppInkMutedColor}" />
            <SolidColorBrush x:Key="AppAccentBrush" Color="{StaticResource AppAccentColor}" />
            <SolidColorBrush x:Key="AppAccentSoftBrush" Color="{StaticResource AppAccentSoftColor}" />
            <SolidColorBrush x:Key="AppSurfaceBrush" Color="{StaticResource AppSurfaceColor}" />
            <SolidColorBrush x:Key="AppCardBrush" Color="{StaticResource AppCardColor}" />
            <SolidColorBrush x:Key="AppBorderBrush" Color="{StaticResource AppBorderColor}" />
            <LinearGradientBrush x:Key="AppSidebarBrush" StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="{StaticResource AppSidebarStartColor}" Offset="0" />
                <GradientStop Color="{StaticResource AppSidebarEndColor}" Offset="1" />
            </LinearGradientBrush>

            <Style x:Key="SidebarButtonStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
                <Setter Property="Margin" Value="0,6" />
                <Setter Property="Padding" Value="12,8" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{StaticResource AppInkBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
            </Style>

            <Style x:Key="SidebarActionButtonStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                <Setter Property="Margin" Value="0,6" />
                <Setter Property="Padding" Value="12,8" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Background" Value="{StaticResource AppAccentBrush}" />
                <Setter Property="Foreground" Value="White" />
            </Style>
            
            <!-- Converters -->
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <converters:HexToColorConverter x:Key="HexToColorConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
